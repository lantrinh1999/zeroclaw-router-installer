#!/bin/sh
# CLIProxyAPI SysV init script for Entware
# Install to: /opt/etc/init.d/S98cliproxyapi

PROG=/opt/cliproxyapi/cli-proxy-api
CONFIG=/opt/cliproxyapi/config.yaml
PIDFILE=/opt/var/run/cliproxyapi.pid
LOGFILE=/opt/var/log/cliproxyapi.log
SOCAT_PIDFILE=/opt/var/run/socat_bridge.pid

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "CLIProxyAPI already running (PID $(cat "$PIDFILE"))"
        return 0
    fi

    echo "Starting CLIProxyAPI..."
    mkdir -p /opt/var/run /opt/var/log

    # Start CLIProxyAPI
    $PROG --config $CONFIG >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    echo "  CLIProxyAPI started (PID $!)"

    # Start socat bridge: IPv4:8317 -> IPv6:8318
    if command -v socat >/dev/null 2>&1; then
        socat TCP4-LISTEN:8317,fork,reuseaddr TCP6:[::1]:8318 &
        echo $! > "$SOCAT_PIDFILE"
        echo "  socat bridge started (PID $!)"
    else
        echo "  WARN: socat not found, IPv4 bridge not started"
    fi
}

stop() {
    echo "Stopping CLIProxyAPI..."
    if [ -f "$PIDFILE" ]; then
        kill "$(cat "$PIDFILE")" 2>/dev/null
        rm -f "$PIDFILE"
    fi
    if [ -f "$SOCAT_PIDFILE" ]; then
        kill "$(cat "$SOCAT_PIDFILE")" 2>/dev/null
        rm -f "$SOCAT_PIDFILE"
    fi
    killall cli-proxy-api 2>/dev/null || true
    killall socat 2>/dev/null || true
    echo "  CLIProxyAPI stopped"
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "CLIProxyAPI is running (PID $(cat "$PIDFILE"))"
    else
        echo "CLIProxyAPI is not running"
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    status)  status ;;
    *)       echo "Usage: $0 {start|stop|restart|status}" ;;
esac
