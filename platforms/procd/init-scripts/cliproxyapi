#!/bin/sh /etc/rc.common

START=98
STOP=10
USE_PROCD=1

PROG=/opt/cliproxyapi/cli-proxy-api
CONFIG=/opt/cliproxyapi/config.yaml

start_service() {
    # Start CLIProxyAPI on port 8318
    procd_open_instance cliproxyapi
    procd_set_param command $PROG --config $CONFIG
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/cliproxyapi.pid
    procd_close_instance

    # Start socat bridge: IPv4:8317 -> IPv6:8318
    # CLIProxyAPI listens on IPv6 (:::8318), so socat must connect via TCP6
    procd_open_instance socat_bridge
    procd_set_param command socat TCP4-LISTEN:8317,fork,reuseaddr TCP6:[::1]:8318
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

# procd handles stop automatically via tracked instances
# No manual killall needed - it interferes with procd state tracking
