# Force LF line endings for all shell scripts
# Prevents CRLF issues when cloning on Windows and running on Linux/OpenWrt
*.sh text eol=lf
*.conf text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Init scripts (no extension) in specific dirs
platforms/procd/init-scripts/* text eol=lf
platforms/entware/init-scripts/* text eol=lf

# Keep Windows batch files as CRLF
*.bat text eol=crlf
