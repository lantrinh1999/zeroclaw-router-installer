#!/bin/sh /etc/rc.common

START=98
STOP=10
USE_PROCD=1

PROG=/opt/cliproxyapi/cli-proxy-api
CONFIG=/opt/cliproxyapi/config.yaml

start_service() {
    # Start CLIProxyAPI on port 8317.
    procd_open_instance cliproxyapi
    procd_set_param command $PROG --config $CONFIG
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/cliproxyapi.pid
    procd_close_instance
}

# procd handles stop automatically via tracked instances
# No manual killall needed - it interferes with procd state tracking
