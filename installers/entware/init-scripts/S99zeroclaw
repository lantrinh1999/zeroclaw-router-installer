#!/bin/sh
# ZeroClaw SysV init script for Entware
# Install to: /opt/etc/init.d/S99zeroclaw

PROG=/opt/bin/zeroclaw
CONFIG_DIR=/root/.zeroclaw
PIDFILE=/opt/var/run/zeroclaw.pid
LOGFILE=/opt/var/log/zeroclaw.log

start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "ZeroClaw already running (PID $(cat "$PIDFILE"))"
        return 0
    fi

    echo "Starting ZeroClaw..."
    mkdir -p /opt/var/run /opt/var/log

    SHELL=/bin/sh HOME=/root PATH=/opt/sbin:/opt/bin:/usr/sbin:/usr/bin:/sbin:/bin \
        $PROG daemon --config-dir $CONFIG_DIR >> "$LOGFILE" 2>&1 &
    echo $! > "$PIDFILE"
    echo "  ZeroClaw started (PID $!)"
}

stop() {
    echo "Stopping ZeroClaw..."
    if [ -f "$PIDFILE" ]; then
        kill "$(cat "$PIDFILE")" 2>/dev/null
        rm -f "$PIDFILE"
    fi
    killall zeroclaw 2>/dev/null || true
    echo "  ZeroClaw stopped"
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "ZeroClaw is running (PID $(cat "$PIDFILE"))"
    else
        echo "ZeroClaw is not running"
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 1; start ;;
    status)  status ;;
    *)       echo "Usage: $0 {start|stop|restart|status}" ;;
esac
